{
  "name": "stagefabric",
  "version": "0.7.0-alpha.1",
  "description": "Compile and execute privacy-safe AI stage graphs across browser, local, edge, and cloud targets.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Antonio Antenore <ant_ant95@hotmail.it>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aantenore/stagefabric.git"
  },
  "homepage": "https://github.com/aantenore/stagefabric#readme",
  "bugs": {
    "url": "https://github.com/aantenore/stagefabric/issues"
  },
  "keywords": [
    "agentic-ai",
    "distributed-inference",
    "edge-ai",
    "privacy",
    "web-ai"
  ],
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./node": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./browser/transformers": {
      "types": "./dist/browser/drivers/transformers/index.d.ts",
      "import": "./dist/browser/drivers/transformers/index.js"
    }
  },
  "bin": {
    "stagefabric": "./dist/entrypoints/cli.js"
  },
  "engines": {
    "node": "^24.15.0 || >=26.0.0"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "browser:dev": "vite --config examples/browser-privacy-bridge/vite.config.ts --host 127.0.0.1 --port 4173",
    "browser:preview": "vite preview --config examples/browser-privacy-bridge/vite.config.ts --host 127.0.0.1 --port 4173",
    "build": "pnpm run clean:dist && pnpm run build:library && pnpm run build:browser-demo",
    "build:browser-demo": "vite build --config examples/browser-privacy-bridge/vite.config.ts",
    "build:library": "tsc -p tsconfig.build.json",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:package",
    "clean:dist": "node scripts/clean-dist.mjs",
    "dev": "tsx src/entrypoints/cli.ts",
    "context:demo": "tsx examples/context-supply-chain.ts",
    "context:benchmark": "tsx src/entrypoints/cli.ts context-benchmark",
    "context:benchmark:enforce": "tsx src/entrypoints/cli.ts context-benchmark --enforce",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --deny-warnings src test scripts examples/browser-privacy-bridge/src examples/browser-privacy-bridge/vite.config.ts e2e playwright.config.ts vitest.config.ts",
    "prepack": "pnpm run build",
    "stagefabric": "tsx src/entrypoints/cli.ts",
    "start": "node dist/entrypoints/cli.js",
    "test": "vitest run",
    "test:browser": "pnpm run build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:package": "node scripts/package-smoke.mjs",
    "test:watch": "vitest",
    "typecheck": "pnpm run typecheck:library && pnpm run typecheck:browser",
    "typecheck:browser": "tsc --noEmit -p tsconfig.browser-demo.json",
    "typecheck:library": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.7",
    "@hono/node-server": "2.0.8",
    "@noble/hashes": "2.2.0",
    "ai": "7.0.22",
    "commander": "15.0.0",
    "hono": "4.12.31",
    "sigstore": "5.0.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
